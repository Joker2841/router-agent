# For LOCAL testing of the escalation path only. The real harness injects these.
# Never bundle a real .env into the image.
FIREWORKS_API_KEY=your_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# On launch day this is published; comma-separated. Example (from the guide):
ALLOWED_MODELS=minimax-m3,kimi-k2p7-code,gemma-4-31b-it,gemma-4-26b-a4b-it,gemma-4-31b-it-nvfp4
# moonshot = never escalate unless local fails (target 0 tokens).
# hybrid   = escalate unverified high-risk answers.
MODE=moonshot
# Set to 1 to route escalations to a Gemma model (for the "Gemma via Fireworks" prize).
ESCALATE_TO_GEMMA=0
